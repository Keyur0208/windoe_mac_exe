{
    "appId": "nilkanth-medico-homs-child.com",
    "productName": "Nilkanth Medico - HOMS Child",
    "artifactName": "Nilkanth-Medico-HOMS-CHILD-Setup-${version}.${ext}",
    "compression": "maximum",
    "asar": true,
    "directories": {
        "output": "electronbuild"
    },
    "files": [
        {
            "from": "obfuscated",
            "to": ".",
            "filter": [
                "**/*",
                "!package.json"
            ]
        },
        {
            "from": "logo.ico",
            "to": "."
        },
        "package.json"
    ],
    "win": {
        "target": [
            {
                "target": "nsis",
                "arch": [
                    "x64",
                    "ia32"
                ]
            }
        ],
        "icon": "logo.ico"
    },
    "linux": {
        "target": [
            "AppImage",
            "deb"
        ],
        "category": "Medical"
    },
    "mac": {
        "target": [
            "dmg",
            "zip"
        ],
        "icon": "logo.icns",
        "category": "public.app-category.medical"
    },
    "dmg": {
        "background": "dmg-background.png"
    },
    "nsis": {
        "oneClick": false,
        "perMachine": true,
        "allowToChangeInstallationDirectory": true,
        "createDesktopShortcut": true,
        "createStartMenuShortcut": true,
        "shortcutName": "Nilkanth HOMS Child",
        "uninstallDisplayName": "Nilkanth Hospital Management System"
    }
}